{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "paradox.config.ts",
    "eslint.config.mjs",
    ".prettierrc.js"
  ],
  "exclude": ["dist", "node_modules"]
}
